    # ─────────────────────────────────────────────
    def _log(self, msg, level="info"):
        self.log_text.config(state=tk.NORMAL)
        self.log_text.insert(tk.END, f"  {msg}\n", level)
        self.log_text.see(tk.END)
        self.log_text.config(state=tk.DISABLED)

    def _status(self, msg):
        self.status_bar.config(text=f"  {msg}")

    def _on_mouse_move(self, event):
        z = self.zoom
        if z > 0:
            x = int(event.x / z)
            y = int(event.y / z)
            cw = self.base_height if self.rotation in (1, 3) else self.base_width
            ch = self.base_width  if self.rotation in (1, 3) else self.base_height
            if 0 <= x < cw and 0 <= y < ch:
                self._status(f"x={x}  y={y}   |   zoom {int(z*100)}%")

    def _sync_scroll(self, *args):
        self.editor.yview(*args)
        self._update_line_numbers()

    def _update_line_numbers(self):
        self.line_numbers.config(state=tk.NORMAL)
        self.line_numbers.delete("1.0", tk.END)
        n = self.editor.get("1.0", tk.END).count('\n')
        self.line_numbers.insert(tk.END, '\n'.join(str(i) for i in range(1, n + 2)))
        self.line_numbers.config(state=tk.DISABLED)

    def _zoom_changed(self, val):
        self.zoom = float(val)
        self.zoom_lbl.config(text=f"{int(self.zoom * 100)}%")
        if hasattr(self, 'canvas'):
            self.render()

    def _update_resolution(self):
        try:
            self.base_width  = max(1, int(self.entry_w.get()))
            self.base_height = max(1, int(self.entry_h.get()))
            self.render()
        except Exception:
            messagebox.showerror("Error", "Resolución inválida.")

    def _on_change(self, event=None):
        self._update_line_numbers()
        if self._after_id:
            self.root.after_cancel(self._after_id)
        self._after_id = self.root.after(350, self._delayed_update)

    def _delayed_update(self):
        self._update_highlight()
        self.render()

    # ─────────────────────────────────────────────
    #  RESALTADO DE SINTAXIS
    # ─────────────────────────────────────────────
    def _update_highlight(self):
        tags = {
            'cmt': '#6a9955', 'str': '#ce9178', 'cha': '#dcdcaa',
            'obj': '#569cd6', 'cmd': '#4ec9b0', 'tft': '#b5cea8',
            'hex': '#b5cea8', 'num': '#b5cea8', 'kw':  '#c586c0',
        }
        txt = self.editor.get("1.0", tk.END)
        for t in tags:
            self.editor.tag_remove(t, "1.0", tk.END)
            self.editor.tag_configure(t, foreground=tags[t])

        def mark(tag, pat, flags=0):
            for m in re.finditer(pat, txt, flags):
                self.editor.tag_add(tag, f"1.0+{m.start()}c", f"1.0+{m.end()}c")

        mark('cmt', r'//.*')
        mark('str', r'"[^"\n]*"')
        mark('cha', r'\(\s*char\s*\)\s*\d+')
        mark('obj', r'\btft\s*\.')
        mark('cmd', r'(?<=\.)[a-zA-Z_][a-zA-Z0-9_]*(?=\s*\()')
        mark('tft', r'\bTFT_[A-Z_]+\b')
        mark('hex', r'\b0x[0-9A-Fa-f]+\b')
        mark('num', r'\b\d+(?:\.\d+)?\b')
        mark('kw',  r'\b(void|int|float|double|bool|char|byte|String|true|false'
                    r'|setup|loop|return|if|else|for|while|do|switch|case|break'
                    r'|const|unsigned|long|short)\b')

    # ─────────────────────────────────────────────
    #  ARCHIVOS
    # ─────────────────────────────────────────────
    def _open_file(self):
        path = filedialog.askopenfilename(
            filetypes=[("Arduino / C++", "*.ino *.cpp *.h *.c"), ("Todos", "*.*")])
        if not path:
            return
        try:
            with open(path, 'r', encoding='utf-8', errors='ignore') as f:
                self.editor.delete("1.0", tk.END)
                self.editor.insert("1.0", f.read())
            self.lbl_file.config(text=os.path.basename(path))
            self._update_line_numbers()
            self._update_highlight()
            self.render()
        except Exception as e:
            messagebox.showerror("Error al abrir", str(e))

    def _save_file(self):
        path = filedialog.asksaveasfilename(
            defaultextension=".ino",
            filetypes=[("Arduino", "*.ino"), ("C++", "*.cpp"), ("Todos", "*.*")])
        if not path:
            return
        try:
            with open(path, 'w', encoding='utf-8') as f:
                f.write(self.editor.get("1.0", tk.END))
            self.lbl_file.config(text=os.path.basename(path))
            self._status(f"Guardado: {os.path.basename(path)}")
        except Exception as e:
            messagebox.showerror("Error al guardar", str(e))

