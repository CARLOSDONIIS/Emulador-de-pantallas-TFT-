    # ═══════════════════════════════════════════════════════════
    #  MOTOR DE RENDERIZADO
    # ═══════════════════════════════════════════════════════════
    def render(self):
        if not hasattr(self, 'canvas'):
            return

        self.canvas.delete("all")
        self.log_text.config(state=tk.NORMAL)
        self.log_text.delete("1.0", tk.END)
        self.log_text.config(state=tk.DISABLED)

        code = self.editor.get("1.0", tk.END)
        self._reset_pen()

        # Detectar rotación global
        rot_m = re.search(r'tft\s*\.\s*setRotation\s*\(\s*(\d)\s*\)', code)
        self.rotation = int(rot_m.group(1)) if rot_m else 0

        landscape = self.rotation in (1, 3)
        cw = self.base_height if landscape else self.base_width
        ch = self.base_width  if landscape else self.base_height

        z  = self.zoom
        zw = int(cw * z)
        zh = int(ch * z)

        self.canvas.config(width=zw, height=zh)
        self.canvas.create_rectangle(0, 0, zw, zh, fill="#000000", outline="")

        n_cmds = 0
        for line_no, raw in enumerate(code.split('\n'), 1):
            # ── PREPROCESO: quitar comentarios + reemplazar (char)N ──
            line = preprocess_line(raw)
            if not line.startswith("tft."):
                continue

            # ── PARSEO: cmd y args ──────────────────────────────────
            m = re.match(
                r'tft\s*\.\s*([a-zA-Z_][a-zA-Z0-9_]*)\s*\((.*)\)\s*;?\s*$',
                line, re.DOTALL)
            if not m:
                continue

            cmd  = m.group(1)
            args = parse_args(m.group(2))
            n_cmds += 1

            try:
                self._exec(cmd, args, z, zw, zh, cw, ch, line_no)
            except Exception as e:
                self._log(f"L{line_no} [{cmd}]: {e}", "error")

        self._status(
            f"OK  ·  {n_cmds} comandos  ·  {cw}x{ch} px  ·  zoom {int(z*100)}%"
        )

    # ═══════════════════════════════════════════════════════════
    #  EJECUTOR  —  todos los comandos TFT_eSPI
    # ═══════════════════════════════════════════════════════════
    def _exec(self, cmd, args, z, zw, zh, cw, ch, line_no):
        p   = self.pen
        iv  = lambda i, d=0:   get_int(args[i], d)   if i < len(args) else d
        fv  = lambda i, d=0.0: get_float(args[i], d) if i < len(args) else d
        col = lambda i: decode_color(args[i]) if i < len(args) else '#FFFFFF'

        # ── PANTALLA ────────────────────────────────────────────
        if cmd == 'fillScreen':
            c = col(0) or '#000000'
            self.screen_bg = c
            self.canvas.create_rectangle(0, 0, zw, zh, fill=c, outline="")

        elif cmd == 'clearScreen':
            self.canvas.create_rectangle(0, 0, zw, zh, fill='#000000', outline="")
            self.screen_bg = '#000000'

        elif cmd in ('setRotation', 'init', 'begin', 'startWrite', 'endWrite',
                     'setAddrWindow', 'setSwapBytes', 'setAttribute',
                     'invertDisplay', 'sleep', 'wakeup', 'pushColors',
                     'setWindow', 'writecommand', 'writedata'):
            pass  # no visuales / ya manejados globalmente

        # ── PIXEL ────────────────────────────────────────────────
        elif cmd == 'drawPixel':
            x, y = iv(0)*z, iv(1)*z
            c    = col(2) or '#FFFFFF'
            sz   = max(1.0, z)
            self.canvas.create_rectangle(x, y, x+sz, y+sz, fill=c, outline="")

        # ── LINEAS ───────────────────────────────────────────────
        elif cmd == 'drawLine':
            lw = max(1, int(z * 0.75))
            self.canvas.create_line(
                iv(0)*z, iv(1)*z, iv(2)*z, iv(3)*z,
                fill=col(4) or '#FFFFFF', width=lw)

        elif cmd == 'drawFastVLine':
            x, y, h_len = iv(0)*z, iv(1)*z, iv(2)*z
            self.canvas.create_line(x, y, x, y+h_len, fill=col(3) or '#FFFFFF')

        elif cmd == 'drawFastHLine':
            x, y, w_len = iv(0)*z, iv(1)*z, iv(2)*z
            self.canvas.create_line(x, y, x+w_len, y, fill=col(3) or '#FFFFFF')

        # ── RECTANGULOS ──────────────────────────────────────────
        elif cmd == 'drawRect':
            x, y, w, h = iv(0)*z, iv(1)*z, iv(2)*z, iv(3)*z
            self.canvas.create_rectangle(x, y, x+w, y+h,
                                         outline=col(4) or '#FFFFFF', fill="")

        elif cmd == 'fillRect':
            x, y, w, h = iv(0)*z, iv(1)*z, iv(2)*z, iv(3)*z
            self.canvas.create_rectangle(x, y, x+w, y+h,
                                         fill=col(4) or '#FFFFFF', outline="")

        elif cmd in ('drawRoundRect', 'fillRoundRect'):
            x, y, w, h = iv(0)*z, iv(1)*z, iv(2)*z, iv(3)*z
            r      = max(1, iv(4)) * z
            c      = col(5) or '#FFFFFF'
            filled = 'fill' in cmd
            fc     = c  if filled else ""
            oc     = "" if filled else c
            r2     = r * 2
            self.canvas.create_rectangle(x+r, y,   x+w-r, y+h,   fill=fc, outline="")
            self.canvas.create_rectangle(x,   y+r, x+w,   y+h-r, fill=fc, outline="")
            for ox, oy in [(x, y), (x+w-r2, y), (x, y+h-r2), (x+w-r2, y+h-r2)]:
                self.canvas.create_oval(ox, oy, ox+r2, oy+r2, fill=fc, outline=oc)
            if not filled:
                self.canvas.create_line(x+r,   y,     x+w-r, y,     fill=c)
                self.canvas.create_line(x+r,   y+h,   x+w-r, y+h,   fill=c)
                self.canvas.create_line(x,     y+r,   x,     y+h-r, fill=c)
                self.canvas.create_line(x+w,   y+r,   x+w,   y+h-r, fill=c)

        elif cmd == 'drawSmoothRoundRect':
            x, y  = iv(0)*z, iv(1)*z
            r_out = iv(2)*z
            w, h  = iv(4)*z, iv(5)*z
            c     = col(6) or '#FFFFFF'
            self.canvas.create_rectangle(x, y, x+w, y+h, outline=c, fill="")

        # ── CIRCULOS ─────────────────────────────────────────────
        elif cmd == 'drawCircle':
            x, y, r = iv(0)*z, iv(1)*z, iv(2)*z
            self.canvas.create_oval(x-r, y-r, x+r, y+r,
                                    outline=col(3) or '#FFFFFF', fill="")

        elif cmd == 'fillCircle':
            x, y, r = iv(0)*z, iv(1)*z, iv(2)*z
            self.canvas.create_oval(x-r, y-r, x+r, y+r,
                                    fill=col(3) or '#FFFFFF', outline="")

        elif cmd in ('drawCircleHelper', 'fillCircleHelper'):
            pass  # helpers internos de bajo nivel

        # ── ELIPSES ──────────────────────────────────────────────
        elif cmd == 'drawEllipse':
            x, y, rx, ry = iv(0)*z, iv(1)*z, iv(2)*z, iv(3)*z
            self.canvas.create_oval(x-rx, y-ry, x+rx, y+ry,
                                    outline=col(4) or '#FFFFFF', fill="")

        elif cmd == 'fillEllipse':
            x, y, rx, ry = iv(0)*z, iv(1)*z, iv(2)*z, iv(3)*z
            self.canvas.create_oval(x-rx, y-ry, x+rx, y+ry,
                                    fill=col(4) or '#FFFFFF', outline="")

        # ── TRIANGULOS ───────────────────────────────────────────
        elif cmd == 'drawTriangle':
            pts = [iv(i)*z for i in range(6)]
            self.canvas.create_polygon(pts, outline=col(6) or '#FFFFFF', fill="")

        elif cmd == 'fillTriangle':
            pts = [iv(i)*z for i in range(6)]
            self.canvas.create_polygon(pts, fill=col(6) or '#FFFFFF', outline="")

        # ── ARCOS ────────────────────────────────────────────────
        elif cmd in ('drawArc', 'drawSmoothArc'):
            x, y  = iv(0)*z, iv(1)*z
            r_out = iv(2)*z
            r_in  = iv(3)*z
            start = fv(4, 0)
            end   = fv(5, 360)
            c     = col(6) or '#FFFFFF'
            ext   = end - start
            if ext <= 0:
                ext += 360
            thick = max(1, int(r_out - r_in))
            self.canvas.create_arc(
                x-r_out, y-r_out, x+r_out, y+r_out,
                start=-start, extent=-ext,
                outline=c, width=thick, style=tk.ARC)

        elif cmd == 'drawWideLine':
            x0, y0 = iv(0)*z, iv(1)*z
            x1, y1 = iv(2)*z, iv(3)*z
            wd     = max(1, int(iv(4)*z))
            c      = col(5) or '#FFFFFF'
            self.canvas.create_line(x0, y0, x1, y1, fill=c, width=wd,
                                    capstyle=tk.ROUND)

        # ── IMAGENES / BITMAPS (marcador visual) ─────────────────
        elif cmd in ('drawBitmap', 'drawXBitmap', 'pushImage',
                     'pushSprite', 'drawRGBBitmap', 'drawGrayscaleBitmap',
                     'drawIndexedBitmap'):
            x, y = iv(0)*z, iv(1)*z
            w    = max(8, iv(2, 16))*z
            h    = max(8, iv(3, 16))*z
            self.canvas.create_rectangle(x, y, x+w, y+h,
                                         outline='#3a3a3a', fill='#111',
                                         dash=(3, 3))
            self.canvas.create_line(x, y, x+w, y+h, fill='#2a2a2a')
            self.canvas.create_line(x+w, y, x, y+h, fill='#2a2a2a')
            self.canvas.create_text(x+w/2, y+h/2, text="IMG",
                                    fill="#444", font=("Consolas", 8))

        # ── SETTERS DE TEXTO ─────────────────────────────────────
        elif cmd == 'setTextColor':
            p['color']    = decode_color(args[0]) or '#FFFFFF' if args else '#FFFFFF'
            p['bg_color'] = decode_color(args[1]) if len(args) > 1 else None

        elif cmd == 'setTextSize':
            p['size'] = max(1, iv(0, 1))

        elif cmd == 'setTextFont':
            p['font'] = iv(0, 1)

        elif cmd == 'setTextDatum':
            p['datum'] = iv(0, 0)

        elif cmd == 'setTextPadding':
            p['padding'] = iv(0, 0)

        elif cmd == 'setTextWrap':
            p['wrap'] = args[0].strip().lower() not in ('false', '0') if args else True

        elif cmd == 'setCursor':
            p['x'] = iv(0)
            p['y'] = iv(1)

        elif cmd in ('setFreeFont', 'setFont', 'loadFont', 'unloadFont',
                     'getCursorX', 'getCursorY',
                     'textWidth', 'fontHeight',
                     'alphaBlend', 'color565', 'color8to16', 'color16to24',
                     'getSetup', 'calibrateTouch', 'getTouch',
                     'createSprite', 'deleteSprite', 'fillSprite',
                     'setPivot', 'getPivotX', 'getPivotY',
                     'pushRotated', 'rotateSprite',
                     'width', 'height', 'getRotation'):
            pass  # no visuales o de configuración avanzada

        # ── TEXTO ────────────────────────────────────────────────
        elif cmd in ('print', 'println', 'drawString',
                     'drawCentreString', 'drawRightString',
                     'drawChar', 'drawNumber', 'drawFloat'):
            self._draw_text(cmd, args, z)

        else:
            self._log(f"L{line_no}: '{cmd}' no implementado", "warn")

    # ═══════════════════════════════════════════════════════════
    #  RENDERIZADO DE TEXTO  — cursor acumulativo correcto
    # ═══════════════════════════════════════════════════════════
    def _draw_text(self, cmd, args, z):
        p     = self.pen
        size  = p['size']
        color = p['color'] or '#FFFFFF'
        bg    = p['bg_color']

        # Tamaño de fuente en píxeles de canvas
        fsize = max(6, int(size * 8 * z))
        font  = ("Courier New", fsize, "bold")

        # Métricas de avance del cursor (en px virtuales del display)
        cw_virt = CHAR_W * size
        lh_virt = LINE_H * size

        def clean(s):
            return s.strip().strip('"').strip("'")

        # ── print / println ──────────────────────────────────────
        if cmd in ('print', 'println'):
            text = clean(args[0]) if args else ''

            # Coordenadas en canvas
            cx = p['x'] * z
            cy = p['y'] * z

            # Fondo de texto (setTextColor con 2 args)
            if bg:
                tw = len(text) * cw_virt * z
                th = lh_virt * z
                self.canvas.create_rectangle(cx, cy, cx+tw, cy+th,
                                             fill=bg, outline="")

            self.canvas.create_text(cx, cy, text=text,
                                    fill=color, font=font, anchor="nw")

            # Avance de cursor en píxeles virtuales del display
            if cmd == 'println':
                p['y'] += lh_virt
                p['x']  = 0
            else:
                p['x'] += len(text) * cw_virt

        # ── drawString(text, x, y [, font]) ─────────────────────
        elif cmd == 'drawString':
            text = clean(args[0]) if args else ''
            x    = get_int(args[1], 0) if len(args) > 1 else p['x']
            y    = get_int(args[2], 0) if len(args) > 2 else p['y']
            if len(args) > 3:
                fsize = max(6, int(get_int(args[3], 1) * 8 * z))
                font  = ("Courier New", fsize, "bold")
            self.canvas.create_text(x*z, y*z, text=text,
                                    fill=color, font=font, anchor="nw")

        # ── drawCentreString(text, x, y [, font]) ───────────────
        elif cmd == 'drawCentreString':
            text = clean(args[0]) if args else ''
            x    = get_int(args[1], 0) if len(args) > 1 else p['x']
            y    = get_int(args[2], 0) if len(args) > 2 else p['y']
            if len(args) > 3:
                fsize = max(6, int(get_int(args[3], 1) * 8 * z))
                font  = ("Courier New", fsize, "bold")
            self.canvas.create_text(x*z, y*z, text=text,
                                    fill=color, font=font, anchor="n")

        # ── drawRightString(text, x, y [, font]) ────────────────
        elif cmd == 'drawRightString':
            text = clean(args[0]) if args else ''
            x    = get_int(args[1], 0) if len(args) > 1 else p['x']
            y    = get_int(args[2], 0) if len(args) > 2 else p['y']
            if len(args) > 3:
                fsize = max(6, int(get_int(args[3], 1) * 8 * z))
                font  = ("Courier New", fsize, "bold")
            self.canvas.create_text(x*z, y*z, text=text,
                                    fill=color, font=font, anchor="ne")

        # ── drawChar(x, y, char, fg, bg, size) ──────────────────
        elif cmd == 'drawChar':
            x    = get_int(args[0], 0) if len(args) > 0 else p['x']
            y    = get_int(args[1], 0) if len(args) > 1 else p['y']
            ch_s = clean(args[2])       if len(args) > 2 else '?'
            fg   = decode_color(args[3]) if len(args) > 3 else color
            sz   = get_int(args[5], size) if len(args) > 5 else size
            fs   = max(6, int(sz * 8 * z))
            self.canvas.create_text(x*z, y*z, text=ch_s,
                                    fill=fg or color,
                                    font=("Courier New", fs, "bold"),
                                    anchor="nw")

        # ── drawNumber(n, x, y [, font]) ────────────────────────
        elif cmd == 'drawNumber':
            text = clean(args[0]) if args else '0'
            x    = get_int(args[1], 0) if len(args) > 1 else p['x']
            y    = get_int(args[2], 0) if len(args) > 2 else p['y']
            if len(args) > 3:
                fsize = max(6, int(get_int(args[3], 1) * 8 * z))
                font  = ("Courier New", fsize, "bold")
            self.canvas.create_text(x*z, y*z, text=text,
                                    fill=color, font=font, anchor="nw")

        # ── drawFloat(value, dp, x, y [, font]) ─────────────────
        elif cmd == 'drawFloat':
            val  = clean(args[0]) if args else '0.0'
            dp   = get_int(args[1], 2) if len(args) > 1 else 2
            x    = get_int(args[2], 0) if len(args) > 2 else p['x']
            y    = get_int(args[3], 0) if len(args) > 3 else p['y']
            if len(args) > 4:
                fsize = max(6, int(get_int(args[4], 1) * 8 * z))
                font  = ("Courier New", fsize, "bold")
            try:
                text = f"{float(val):.{dp}f}"
            except Exception:
                text = val
            self.canvas.create_text(x*z, y*z, text=text,
                                    fill=color, font=font, anchor="nw")

