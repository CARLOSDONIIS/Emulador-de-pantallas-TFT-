# --- MOTOR DE COLORES ---
TFT_COLORS = {
    'TFT_BLACK': '#000000', 'TFT_NAVY': '#000080', 'TFT_DARKGREEN': '#008000',
    'TFT_DARKCYAN': '#008080', 'TFT_MAROON': '#800000', 'TFT_PURPLE': '#800080',
    'TFT_OLIVE': '#808000', 'TFT_LIGHTGREY': '#D3D3D3', 'TFT_DARKGREY': '#A9A9A9',
    'TFT_BLUE': '#0000FF', 'TFT_GREEN': '#00FF00', 'TFT_CYAN': '#00FFFF',
    'TFT_RED': '#FF0000', 'TFT_MAGENTA': '#FF00FF', 'TFT_YELLOW': '#FFFF00',
    'TFT_WHITE': '#FFFFFF', 'TFT_ORANGE': '#FFA500', 'TFT_PINK': '#FFC0CB',
    'TFT_GOLD': '#FFD700', 'TFT_SKYBLUE': '#87CEEB', 'TFT_BROWN': '#A52A2A',
    'TFT_VIOLET': '#EE82EE'
}

def decode_color(val_str):
    val_str = val_str.strip()
    if val_str in TFT_COLORS: return TFT_COLORS[val_str]
    if "color565" in val_str:
        try:
            rgb = re.findall(r'\d+', val_str)
            r, g, b = int(rgb[0]), int(rgb[1]), int(rgb[2])
            return f"#{r:02x}{g:02x}{b:02x}"
        except: return "#FFFFFF"
    try:
        if val_str.startswith('0x'): val = int(val_str, 16)
        else: val = int(val_str)
        r = ((val >> 11) & 0x1F) << 3
        g = ((val >> 5) & 0x3F) << 2
        b = (val & 0x1F) << 3
        return f"#{r:02x}{g:02x}{b:02x}"
    except: return "#FFFFFF"

