# ═══════════════════════════════════════════════════════════════
#  TABLA ASCII/UNICODE COMPLETA para (char)N
# ═══════════════════════════════════════════════════════════════
CHAR_TABLE = {
    163: '\u00a3', 165: '\u00a5', 169: '\u00a9', 174: '\u00ae',
    176: '\u00b0', 177: '\u00b1', 178: '\u00b2', 179: '\u00b3',
    181: '\u00b5', 182: '\u00b6', 183: '\u00b7', 186: '\u00ba',
    188: '\u00bc', 189: '\u00bd', 190: '\u00be', 215: '\u00d7',
    247: '\u00f7', 223: '\u00df', 230: '\u00e6', 248: '\u00f8',
    913: '\u0391', 914: '\u0392', 915: '\u0393', 916: '\u0394',
    920: '\u0398', 923: '\u039b', 928: '\u03a0', 931: '\u03a3',
    934: '\u03a6', 937: '\u03a9', 945: '\u03b1', 946: '\u03b2',
    947: '\u03b3', 948: '\u03b4', 952: '\u03b8', 955: '\u03bb',
    960: '\u03c0', 963: '\u03c3', 966: '\u03c6', 969: '\u03c9',
}

def char_to_str(n):
    if n in CHAR_TABLE:
        return CHAR_TABLE[n]
    try:
        c = chr(n)
        if c.isprintable():
            return c
    except Exception:
        pass
    return f'[{n}]'

# ═══════════════════════════════════════════════════════════════
#  DECODIFICADOR DE COLOR
# ═══════════════════════════════════════════════════════════════
def decode_color(val_str):
    val_str = val_str.strip()
    if not val_str:
        return None
    if val_str in TFT_COLORS:
        c = TFT_COLORS[val_str]
        return c if c else None
    if 'color565' in val_str:
        try:
            rgb = re.findall(r'\d+', val_str)
            r, g, b = int(rgb[0]), int(rgb[1]), int(rgb[2])
            return f'#{r:02x}{g:02x}{b:02x}'
        except Exception:
            return '#FFFFFF'
    try:
        v = val_str
        if v.startswith('0x') or v.startswith('0X'):
            val = int(v, 16)
        else:
            val = int(v)
        r = ((val >> 11) & 0x1F) << 3
        g = ((val >> 5)  & 0x3F) << 2
        b = (val & 0x1F) << 3
        return f'#{r:02x}{g:02x}{b:02x}'
    except Exception:
        return '#FFFFFF'

# ═══════════════════════════════════════════════════════════════
#  PARSER DE ARGUMENTOS  (respeta comillas y paréntesis anidados)
# ═══════════════════════════════════════════════════════════════
def parse_args(raw):
    args = []
    depth = 0
    cur = ''
    in_str = False
    for ch in raw:
        if ch == '"' and depth == 0:
            in_str = not in_str
            cur += ch
        elif in_str:
            cur += ch
        elif ch == '(':
            depth += 1
            cur += ch
        elif ch == ')':
            depth -= 1
            cur += ch
        elif ch == ',' and depth == 0:
            args.append(cur.strip())
            cur = ''
        else:
            cur += ch
    if cur.strip():
        args.append(cur.strip())
    return args

def get_int(s, default=0):
    try:
        s = s.strip()
        if s.startswith('0x') or s.startswith('0X'):
            return int(s, 16)
        return int(float(s))
    except Exception:
        return default

def get_float(s, default=0.0):
    try:
        return float(s.strip())
    except Exception:
        return default

def strip_comment(line):
    """Elimina comentarios // sin afectar strings."""
    in_str = False
    i = 0
    while i < len(line):
        if line[i] == '"':
            in_str = not in_str
        if not in_str and line[i:i+2] == '//':
            return line[:i].rstrip()
        i += 1
    return line

def preprocess_line(raw):
    """
    1. Elimina indentación y comentarios //
    2. Convierte (char)N  a la cadena "X"  correcta
    """
    line = strip_comment(raw).strip()
    def replace_char(m):
        n = int(m.group(1))
        return '"' + char_to_str(n) + '"'
    line = re.sub(r'\(\s*char\s*\)\s*(\d+)', replace_char, line)
    return line

