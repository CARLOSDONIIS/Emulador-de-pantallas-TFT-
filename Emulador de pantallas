    def update_resolution(self):
        try:
            self.base_width = int(self.entry_w.get())
            self.base_height = int(self.entry_h.get())
            self.render()
        except: pass

    def update_zoom_ui(self, val):
        self.zoom = float(val)
        self.zoom_lbl.config(text=f"{int(self.zoom * 100)}%")
        self.render()

    def on_code_change(self, event):
        self.update_highlight()
        self.render()

    def update_highlight(self):
        tags = {'cmd': '#4ec9b0', 'str': '#ce9178', 'num': '#b5cea8', 'cmt': '#6a9955', 'obj': '#569cd6'}
        for t, col in tags.items():
            self.editor.tag_remove(t, "1.0", tk.END)
            self.editor.tag_configure(t, foreground=col)
        txt = self.editor.get("1.0", tk.END)
        for m in re.finditer(r'tft\.', txt): self.editor.tag_add('obj', f"1.0+{m.start()}c", f"1.0+{m.end()}c")
        for m in re.finditer(r'(?<=\.)[a-zA-Z0-9_]+(?=\()', txt): self.editor.tag_add('cmd', f"1.0+{m.start()}c", f"1.0+{m.end()}c")
        for m in re.finditer(r'"[^"]*"|\(char\)\d+', txt): self.editor.tag_add('str', f"1.0+{m.start()}c", f"1.0+{m.end()}c")
        for m in re.finditer(r'\b\d+\b|0x[0-9A-Fa-f]+|TFT_[A-Z_]+', txt): self.editor.tag_add('num', f"1.0+{m.start()}c", f"1.0+{m.end()}c")
        for m in re.finditer(r'//.*', txt): self.editor.tag_add('cmt', f"1.0+{m.start()}c", f"1.0+{m.end()}c")

    def render(self):
        self.canvas.delete("all")
        code = self.editor.get("1.0", tk.END)
        
        # Escaneo flexible de rotaci贸n: busca tft.setRotation(n)
        rot_match = re.search(r'tft\s*\.\s*setRotation\s*\(\s*(\d)\s*\)', code)
        self.rotation = int(rot_match.group(1)) if rot_match else 0
        
        # Intercambiar dimensiones si es horizontal (1 o 3)
        is_landscape = self.rotation in [1, 3]
        curr_w = self.base_height if is_landscape else self.base_width
        curr_h = self.base_width if is_landscape else self.base_height
        
        # Ajustar tama帽o del Canvas seg煤n Zoom
        zw, zh = int(curr_w * self.zoom), int(curr_h * self.zoom)
        self.canvas.config(width=zw, height=zh)
        self.canvas.create_rectangle(0, 0, zw, zh, fill="black", outline="")

        pen = {'x': 0, 'y': 0, 'size': 1, 'color': '#FFFFFF'}
        lines = code.split('\n')

        for line in lines:
            l = line.strip().replace('(char)176', '掳')
            if not l.startswith("tft.") or "setRotation" in l: continue
            try:
                # Extraer comando y argumentos
                match = re.search(r'tft\.(.*?)\((.*)\)', l)
                if not match: continue
                cmd, args_raw = match.group(1), match.group(2)
                
                # Manejo de cadenas de texto y s铆mbolos
                args = []
                if '"' in args_raw:
                    m_str = re.search(r'"(.*?)"', args_raw)
                    if m_str:
                        args.append(f'"{m_str.group(1)}"')
                        args_raw = args_raw.replace(f'"{m_str.group(1)}"', 'TMP_STR')
                elif '掳' in args_raw:
                    args.append('"掳"')
                    args_raw = args_raw.replace('掳', 'TMP_STR')

                # Separar el resto de argumentos
                other_args = [x.strip() for x in args_raw.split(',') if x.strip() and x != 'TMP_STR']
                args.extend(other_args)

                if cmd == "fillScreen":
                    self.canvas.create_rectangle(0, 0, zw, zh, fill=decode_color(args[0]), outline="")
                elif cmd == "setCursor":
                    pen['x'], pen['y'] = int(args[0]), int(args[1])
                elif cmd == "setTextSize":
                    pen['size'] = int(args[0])
                elif cmd == "setTextColor":
                    pen['color'] = decode_color(args[0])
                elif cmd in ["print", "println"]:
                    txt = args[0].replace('"', '')
                    f_size = int(pen['size'] * 8 * self.zoom) 
                    self.canvas.create_text(pen['x']*self.zoom, pen['y']*self.zoom, text=txt, fill=pen['color'],
                                            font=("Courier New", f_size, "bold"), anchor="nw")
                    if cmd == "println": pen['y'] += int(pen['size'] * 10) 
                    else: pen['x'] += len(txt) * int(pen['size'] * 6)
                elif "Rect" in cmd:
                    # x, y, w, h, [r], col
                    x, y, w, h = [int(a)*self.zoom for a in args[:4]]
                    col = decode_color(args[5] if "RoundRect" in cmd else args[4])
                    if "fill" in cmd: self.canvas.create_rectangle(x, y, x+w, y+h, fill=col, outline="")
                    else: self.canvas.create_rectangle(x, y, x+w, y+h, outline=col)
                elif "Circle" in cmd:
                    x, y, r = [int(a)*self.zoom for a in args[:3]]
                    col = decode_color(args[3])
                    if "fill" in cmd: self.canvas.create_oval(x-r, y-r, x+r, y+r, fill=col, outline="")
                    else: self.canvas.create_oval(x-r, y-r, x+r, y+r, outline=col)
                elif cmd == "drawLine":
                    self.canvas.create_line(int(args[0])*self.zoom, int(args[1])*self.zoom, 
                                            int(args[2])*self.zoom, int(args[3])*self.zoom, fill=decode_color(args[4]))
            except: pass

    def open_file(self):
        path = filedialog.askopenfilename(filetypes=[("Arduino", "*.ino *.cpp *.h"), ("Todos", "*.*")])
        if path:
            try:
                with open(path, 'r', encoding='utf-8', errors='ignore') as f:
                    self.editor.delete("1.0", tk.END)
                    self.editor.insert("1.0", f.read())
                self.lbl_filename.config(text=os.path.basename(path))
                self.update_highlight()
                self.render()
            except: pass

    def save_file_as(self):
        path = filedialog.asksaveasfilename(defaultextension=".ino", filetypes=[("Arduino", "*.ino")])
        if path:
            try:
                with open(path, 'w', encoding='utf-8') as f:
                    f.write(self.editor.get("1.0", tk.END))
                self.lbl_filename.config(text=os.path.basename(path))
            except: pass

